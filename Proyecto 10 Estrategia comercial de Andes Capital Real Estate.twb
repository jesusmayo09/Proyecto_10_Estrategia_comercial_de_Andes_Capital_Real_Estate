      <aliases enabled='yes' />
      <column caption='Ticket Promedio' datatype='real' name='[Calculation_1733945605091328]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([precio_venta])' />
      </column>
      <column caption='Cantidad Ventas' datatype='integer' name='[Calculation_1733945605402625]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id_venta])' />
      </column>
      <column caption='Ingreso Total' datatype='integer' name='[Calculation_1733945605566466]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [id_venta] : SUM([precio_venta])}' />
      </column>
      <column caption='Comision Total' datatype='integer' name='[Calculation_1733945605758979]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [id_venta] : sum([monto_comision])}' />
      </column>
      <column caption='Total Ordenes' datatype='integer' name='[Calculation_1733945606172676]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='count([id_venta])' />
      </column>
      <column caption='Last year yoy?' datatype='integer' name='[Calculation_1733945610838021]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([precio_venta])) - LOOKUP(ZN(SUM([precio_venta])), -1))'>
          <table-calc level-break='[federated.0sc209r1kxc4ma13gc9p30ffw8kv].[qr:fecha:ok]' ordering-field='[federated.0sc209r1kxc4ma13gc9p30ffw8kv].[fecha]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Ventas Año Actual (YTD)' datatype='integer' name='[Calculation_1733945611259910]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED YEAR([fecha]) : SUM([precio_venta]) }' />
      </column>
      <column caption='Ventas Anio24' datatype='integer' name='[Calculation_1733945623191559]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [anio] = 2024&#13;&#10;THEN [precio_venta]&#13;&#10;END' />
      </column>
      <column caption='Ventas Anio23' datatype='integer' name='[Calculation_1733945624186888]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [anio] = 2023&#13;&#10;THEN [precio_venta]&#13;&#10;END' />
      </column>
      <column caption='Ingresos Por Anio' datatype='integer' name='[Calculation_1733945625444361]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [fecha] : SUM([precio_venta]) }' />
      </column>
      <column caption='Fecha Primera Compra' datatype='date' name='[Calculation_1733945632440330]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [id_cliente] : MIN([fecha]) }' />
      </column>
      <column caption='Meses Desde Inicio' datatype='integer' name='[Calculation_1733945632600075]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, [Calculation_1733945632440330], [fecha])' />
      </column>
      <column caption='Mes de cohorte' datatype='datetime' name='[Calculation_1733945633669132]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [Calculation_1733945632440330])' />
      </column>
      <column caption='Retencion %' datatype='real' name='[Calculation_1733945638354957]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([id_venta]) / LOOKUP(COUNTD([id_venta]), FIRST())'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
