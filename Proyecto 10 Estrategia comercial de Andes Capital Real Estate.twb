  <worksheets>
    <worksheet name='Analisis Cohorte'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#4e79a7'>Analisis de Cohorte</run>
            <run>Æ&#10;</run>
            <run fontsize='9'>Que porcentaje de clientes sigue haciendo compras despues del primer mes</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='dim_clientes+' name='federated.0sc209r1kxc4ma13gc9p30ffw8kv' />
          </datasources>
          <datasource-dependencies datasource='federated.0sc209r1kxc4ma13gc9p30ffw8kv'>
            <column caption='Fecha Primera Compra' datatype='date' name='[Calculation_1733945632440330]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{ FIXED [id_cliente] : MIN([fecha]) }' />
            </column>
            <column caption='Meses Desde Inicio' datatype='integer' name='[Calculation_1733945632600075]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, [Calculation_1733945632440330], [fecha])' />
            </column>
            <column caption='Mes de cohorte' datatype='datetime' name='[Calculation_1733945633669132]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [Calculation_1733945632440330])' />
            </column>
            <column caption='Retencion %' datatype='real' name='[Calculation_1733945638354957]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([id_venta]) / LOOKUP(COUNTD([id_venta]), FIRST())'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Fecha' datatype='date' name='[fecha]' role='dimension' type='ordinal' />
            <column caption='Id Cliente' datatype='string' name='[id_cliente]' role='dimension' type='nominal' />
            <column caption='Id Venta' datatype='string' name='[id_venta]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1733945633669132]' derivation='MY' name='[my:Calculation_1733945633669132:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_1733945632600075]' derivation='None' name='[none:Calculation_1733945632600075:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_1733945638354957]' derivation='User' name='[usr:Calculation_1733945638354957:qk:9]' pivot='key' type='quantitative'>
              <table-calc ordering-field='[federated.0sc209r1kxc4ma13gc9p30ffw8kv].[Calculation_1733945632600075]' ordering-type='Field' />
